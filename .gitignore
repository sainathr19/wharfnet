/target
.wharfnet/

# Local editor/agent tooling config — machine-specific, not part of the crate.
/.claude/

# Isolated temp dirs the docker-backed e2e tests create under the crate root
# (auto-removed on drop; ignored so a hard-killed run never leaves them staged).
/.tmp*/

# A wharfnet.toml is a downstream project's config; never commit one from this
# repo (it would change wharfnet's own dev/test behaviour).
/wharfnet.toml

# Foundry build artifacts (the token sources compile inside a container; these
# only appear if you run `forge` in src/resources/contracts/ directly).
src/resources/contracts/out/
src/resources/contracts/cache/
src/resources/contracts/broadcast/
src/resources/contracts/lib/

# Scarb (Cairo) build artifacts — produced by gen-starknet-token-state.sh; the
# baked replay under resources/state is the committed artifact, not these.
src/resources/contracts/starknet/target/
